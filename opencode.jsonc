{
  "$schema": "https://opencode.ai/config.json",
  "instructions": ["AGENTS.md"],

  "permission": {
    "edit": "allow",
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "skill": "allow",
    "bash": {
      // ============================================================
      // Python 開発（uv / python / pip / pytest / lint / 型）
      // ============================================================
      "uv *": "allow",
      "python*": "allow",
      "python3*": "allow",
      "py.test*": "allow",
      "pip*": "allow",
      "pip3*": "allow",
      "pytest*": "allow",
      "ruff*": "allow",
      "mypy*": "allow",
      "coverage*": "allow",
      "pre-commit*": "allow",
      "timeout*": "allow",

      // ============================================================
      // バージョン管理 / GitHub
      // ============================================================
      "git *": "allow",
      "gh *": "allow",

      // ============================================================
      // Node / JS（.opencode/ の package.json 対応）
      // ============================================================
      "node*": "allow",
      "npm*": "allow",
      "npx*": "allow",
      "pnpm*": "allow",
      "yarn*": "allow",
      "bun*": "allow",
      "deno*": "allow",

      // ============================================================
      // ビルド / コンテナ
      // ============================================================
      "make*": "allow",
      "cmake*": "allow",
      "ninja*": "allow",
      "meson*": "allow",
      "gcc*": "allow",
      "g++*": "allow",
      "docker*": "allow",
      "docker-compose*": "allow",
      "podman*": "allow",

      // ============================================================
      // 読み取り / 検索 / データ加工
      // ============================================================
      "cat*": "allow",
      "ls*": "allow",
      "dir*": "allow",
      "head*": "allow",
      "tail*": "allow",
      "grep*": "allow",
      "find*": "allow",
      "findstr*": "allow",
      "wc*": "allow",
      "tree*": "allow",
      "sort*": "allow",
      "cut*": "allow",
      "tr*": "allow",
      "diff*": "allow",
      "stat*": "allow",
      "file*": "allow",
      "which*": "allow",
      "where*": "allow",
      "date*": "allow",
      "pwd*": "allow",
      "env*": "allow",
      "printenv*": "allow",
      "du*": "allow",
      "df*": "allow",
      "uname*": "allow",
      "whoami*": "allow",
      "id*": "allow",
      "awk*": "allow",
      "sed*": "allow",
      "xargs*": "allow",
      "rg*": "allow",
      "ag*": "allow",
      "ack*": "allow",
      "jq*": "allow",
      "yq*": "allow",
      "xxd*": "allow",
      "od*": "allow",
      "base64*": "allow",
      "less*": "allow",
      "more*": "allow",
      "tee*": "allow",
      "yes*": "allow",
      "sleep*": "allow",
      "wait*": "allow",
      "clear*": "allow",

      // ============================================================
      // プロセス / システム管理
      // ============================================================
      "ps*": "allow",
      "top*": "allow",
      "htop*": "allow",
      "kill*": "allow",
      "killall*": "allow",
      "pkill*": "allow",
      "pidof*": "allow",

      // ============================================================
      // ネットワーク / リモート操作
      // ============================================================
      "ssh*": "allow",
      "scp*": "allow",
      "rsync*": "allow",
      "ping*": "allow",
      "host*": "allow",
      "nslookup*": "allow",
      "ip*": "allow",
      "ifconfig*": "allow",
      "netstat*": "allow",
      "ss*": "allow",

      // ============================================================
      // ファイル操作（可逆）
      // ============================================================
      "mkdir*": "allow",
      "touch*": "allow",
      "cp*": "allow",
      "mv*": "allow",
      "chmod*": "allow",
      "ln*": "allow",
      "tar*": "allow",
      "unzip*": "allow",
      "zip*": "allow",
      "gzip*": "allow",
      "gunzip*": "allow",

      // ============================================================
      // Bash ビルトイン / 環境変数
      // ============================================================
      "cd*": "allow",
      "set*": "allow",
      "unset*": "allow",
      "export*": "allow",
      "source*": "allow",
      "eval*": "allow",
      "echo*": "allow",
      "type*": "allow",
      "command*": "allow",
      "hash*": "allow",
      "true*": "allow",
      "false*": "allow",
      "test*": "allow",
      "$env*": "allow",
      "PYTHONUTF8*": "allow",

      // ============================================================
      // ask（明示的に確認）
      // ============================================================
      "rm*": "ask",
      "chown*": "ask",
      "curl*": "ask",
      "wget*": "ask",

      // ============================================================
      // フォールバック（未指定のコマンドは全て確認）
      // ============================================================
      "*": "ask"
    }
  }
}
