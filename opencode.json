{
  "$schema": "https://opencode.ai/config.json",
  "model": "opencode-go/minimax-m3",
  "small_model": "opencode-go/minimax-m3",
  "default_agent": "build",
  "instructions": [
    "AGENTS.md",
    "docs/01-roadmap.md",
    "docs/02-code-structure.md"
  ],
  "permission": {
    "edit": "allow",
    "bash": {
      "*": "ask",
      "git status*": "allow",
      "git log*": "allow",
      "git diff*": "allow",
      "git branch*": "allow",
      "git switch main": "allow",
      "git switch -c *": "allow",
      "git pull*": "allow",
      "git fetch*": "allow",
      "git add*": "allow",
      "git commit*": "ask",
      "git push*": "ask",
      "git push -u *": "ask",
      "git stash*": "ask",
      "git stash pop*": "ask",
      "git reset*": "ask",
      "git restore*": "ask",
      "git rm*": "ask",
      "uv run pytest*": "allow",
      "uv run python*": "allow",
      "uv run mypy*": "allow",
      "uv pip*": "allow",
      "uv sync*": "allow",
      "python -m katrain*": "allow",
      "python -m pytest*": "allow",
      "python -m mypy*": "allow",
      "ls*": "allow",
      "ls *": "allow",
      "cat*": "allow",
      "cat *": "allow",
      "find*": "allow",
      "find *": "allow",
      "grep*": "allow",
      "grep *": "allow",
      "tree*": "allow",
      "tree *": "allow",
      "wc*": "allow",
      "wc *": "allow",
      "echo*": "allow",
      "echo *": "allow",
      "head*": "allow",
      "tail*": "allow",
      "pwd": "allow",
      "gh pr view*": "allow",
      "gh pr checks*": "allow",
      "gh pr list*": "allow",
      "gh pr create*": "ask",
      "gh pr merge*": "ask",
      "gh run list*": "allow",
      "gh run view*": "allow",
      "gh run rerun*": "ask",
      "gh workflow list*": "allow",
      "gh api *": "ask",
      "rm -rf *": "deny",
      "rm -rf/*": "deny",
      "git push --force*": "deny",
      "git push -f*": "deny",
      "git reset --hard*": "deny",
      "git clean -fd*": "deny"
    },
    "webfetch": "allow",
    "external_directory": "deny"
  },
  "agent": {
    "build": {
      "description": "コード実装・テスト・コミットまで担当",
      "prompt": "{file:./.opencode/agent/build.md}"
    },
    "plan": {
      "description": "計画・設計専用。ファイル変更は提案のみ",
      "prompt": "{file:./.opencode/agent/plan.md}"
    }
  }
}
